# OpenAI
OPENAI_API_KEY=<your-openai-api-key>
OPENAI_LLM_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_LLM_MODEL_ENRICHMENT=

#Gemini
USE_GEMINI= <true or false>
USE_GEMINI_ENRICHMENT= <true or false>
GEMINI_API_KEY=
GEMINI_MODEL=


# Qdrant Cloud
QDRANT_URL=<your-qdrant-url>
QDRANT_API_KEY=<your-qdrant-api-key>
REGULATORY_COLLECTION=<your-regulatory-collection-name>
POLICIES_COLLECTION=<your-policies-collection-name>
COMPLIANCE_DENSE_NAME=<your-compliance-dense-name>
POLICY_DENSE_NAME=<your-policy-dense-name>
POLICY_SPARSE_NAME=<your-policy-sparse-name>


# Langfuse
LANGFUSE_PUBLIC_KEY=<your-langfuse-public-key>
LANGFUSE_SECRET_KEY=<your-langfuse-secret-key>
LANGFUSE_BASE_URL=<your-langfuse-base-url>
LANGFUSE_HOST=http://localhost:3000

# Arize Phoenix (local)
PHOENIX_ENDPOINT=http://localhost:6006
PHOENIX_EXTERNAL=<true or false>

# LangWatch
LANGWATCH_API_KEY=

#HuggingFace
HUGGINGFACE_API_KEY=

#Reranker
VOYAGE_API_KEY=
